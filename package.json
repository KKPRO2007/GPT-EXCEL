{
  "name": "gpt-excel",
  "version": "1.0.0",
  "main": "dist/main/main.js",
  "scripts": {
    "compile": "tsc -p tsconfig.node.json",
    "dev": "cross-env NODE_ENV=development npm run compile && concurrently \"vite\" \"electron .\"",
    "build": "npm run compile && vite build",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.example.gpt-excel",
    "productName": "GPT-EXCEL",
    "directories": { "output": "release" },
    "files": [ "dist/**/*", "dist-react/**/*", "node_modules/**/*" ],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@reduxjs/toolkit": "^2.2.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.26.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.3",
    "vite": "^5.3.5"
  }
}